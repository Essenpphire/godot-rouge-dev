[sub_resource type="GDScript" id="GDScript_duupr"]
script/source = "extends CanvasLayer

@onready var HpBar : TextureProgressBar = $Control/HealthBar
@onready var Player : Character = $\"/root/Game/Player\"
#@onready var Enemies : Node2D = $\"/root/Game/EnemyMarkers\"

const MIN_HP_LENGTH : int = 10
const MAX_HP_LENGTH : int = 55
var max_hp : float = 100.0

func _ready() -> void:
	max_hp = Player.HP
	_update_hp_bar(MAX_HP_LENGTH)
\"\"\"
	if is_instance_valid(Enemies):
		for i in range(Enemies.get_child_count()):
			var _HP = Label.new()
			_HP.position = Vector2.ZERO
			_HP.position.x += 50 * (i + 1)
			$\"Control\".add_child(_HP)
\"\"\"

## @todo 偷懒了，实际上UI是由专门信号控制的
func _physics_process(delta: float) -> void:
	\"\"\"
	for i in range(Enemies.get_child_count()):
		var label : Label = $Control.get_child(i + 1)
		label.text = str(Enemies.get_child(i).HP)
	\"\"\"

## 更新血条
func _update_hp_bar(new_hp : float) -> void:
	var tween = create_tween()
	# 丝滑扣血
	tween.tween_property(HpBar, \"value\", new_hp, 0.5)\\
		 .set_trans(Tween.TRANS_QUINT)\\
		 .set_ease(Tween.EASE_OUT)
	tween.play()

func _on_player_hp_change(new_hp: float) -> void:
	var n_hp : float = (MAX_HP_LENGTH - MIN_HP_LENGTH) * new_hp / max_hp + MIN_HP_LENGTH
	print(new_hp)
	_update_hp_bar(n_hp)
"

