resource_name = "world"
script/source = "\"\"\"代码待复用……\"\"\"
extends Node2D
@onready var player = $\"player\"
# @onready var ground_layer = $\"TileMap/地块\"

func _ready() -> void:
	# var _rect = ground_layer.get_used_rect() 
	# var _cell_size = ground_layer.tile_set.tile_size
	# 单元格大小统一为32*32
	# var xs = _rect.position.x * 32
	# var ys = _rect.position.y * 32
	# var xe = (_rect.end.x - 1) * 32
	# var ye = (_rect.end.y - 1) * 32
	GameManager.cameraLimit(-608, -302, 509, 320)
	# 选出生点
	if GameManager.fst_spawn == true:
		player.position = Vector2(36, 162)
		GameManager.fst_spawn = false
	else:
		player.position = Vector2(501, -52)
	
func _process(delta: float) -> void:
	pass

func _on_右边路传送点_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"Player\"):
		GameManager.changeScene(\"res://src/maps/level1_主世界/主世界_地牢入口.tscn\")
		#GameManager.changeScene(\"res://src/maps/level2_地牢/地牢_第一层_出生房.tscn\")
"

