script/source = "extends Node2D

func _ready() -> void:
	GameManager.cameraLimit(-576, -308, 574, 320)
	
func _process(delta: float) -> void:
	pass

func _on_左边路传送点_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"Player\"):
		GameManager.changeScene(\"res://src/maps/level1_主世界/主世界_出生点.tscn\")

func _on_地牢传送点_body_entered(body: Node2D) -> void:
	if body.is_in_group(\"Player\"):
		GameManager.changeScene(\"res://src/maps/level2_地牢/地牢_第一层.tscn\")
		#pass
"

